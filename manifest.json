<!-- saved from url=(0125)file:///C:/Users/bomi6/Downloads/%E3%83%96%E3%83%A9%E3%83%B3%E3%83%89%E5%88%A5ToDo%E5%BA%83%E5%91%8A%E8%A8%88%E7%94%BB_2.html -->
<html lang="ja"><head><meta http-equiv="Content-Type" content="text/html; charset=UTF-8">

<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="theme-color" content="#191512">
<title>ブランド別 ToDo &amp; 広告計画 — Rose Garden Co.</title>
<link rel="preconnect" href="https://fonts.googleapis.com/">
<link rel="preconnect" href="https://fonts.gstatic.com/" crossorigin="">
<link href="./ブランド別 ToDo &amp; 広告計画 — Rose Garden Co._files/css2" rel="stylesheet">
<style>
  :root{
    --paper:#F2ECE0;--paper2:#FBF7EF;--ink:#191512;--ink-soft:#5C5247;
    --muted:#8E8270;--accent:#BE4128;--accent-soft:#E9C6B7;--line:#DAD0BE;--card:#FCFAF4;
  }
  *{margin:0;padding:0;box-sizing:border-box}
  html{-webkit-text-size-adjust:100%}
  body{
    font-family:"Zen Kaku Gothic New",sans-serif;background:var(--paper);color:var(--ink);
    line-height:1.62;-webkit-font-smoothing:antialiased;
    background-image:radial-gradient(circle at 18% -10%,#F8F2E6 0%,transparent 55%),radial-gradient(circle at 100% 8%,#EFE7D6 0%,transparent 45%);
    min-height:100vh;
  }
  .wrap{max-width:480px;margin:0 auto;padding:0 22px 60px;}
  .bar{display:flex;align-items:center;justify-content:space-between;padding:24px 0 26px;}
  .brand{display:flex;align-items:center;gap:10px;}
  .mark{width:30px;height:30px;border:1.5px solid var(--ink);border-radius:7px;position:relative;flex:none;}
  .mark::before{content:"";position:absolute;inset:6px;border:1.5px solid var(--accent);border-radius:3px;}
  .brand b{font-weight:700;font-size:15px;letter-spacing:.04em;}
  .brand span{display:block;font-family:"Fraunces",serif;font-size:9.5px;letter-spacing:.3em;color:var(--muted);text-transform:uppercase;}
  .date{font-family:"Fraunces",serif;font-size:12px;color:var(--ink-soft);letter-spacing:.05em;}

  .reveal{opacity:0;transform:translateY(14px);animation:rise .7s cubic-bezier(.2,.7,.2,1) forwards;}
  @keyframes rise{to{opacity:1;transform:none}}

  .eyebrow{font-family:"Fraunces",serif;font-size:10px;letter-spacing:.32em;text-transform:uppercase;color:var(--accent);margin-bottom:12px;display:flex;align-items:center;gap:8px;}
  .eyebrow::after{content:"";flex:1;height:1px;background:var(--line);}

  .lead{font-family:"Shippori Mincho",serif;font-weight:800;font-size:24px;line-height:1.45;margin-bottom:8px;}
  .lead em{font-style:normal;color:var(--accent);}
  .lead-sub{font-size:12.5px;color:var(--ink-soft);margin-bottom:30px;}

  /* shared foundation list */
  .found{margin-bottom:30px;}
  .f{display:flex;gap:11px;padding:11px 0;border-bottom:1px solid var(--line);}
  .f:first-of-type{border-top:1px solid var(--line);}
  .f .fn{font-family:"Fraunces",serif;font-size:13px;color:var(--accent);width:18px;flex:none;}
  .f .ft{font-size:12.5px;}
  .f .ft b{font-weight:700;}

  /* matrix */
  .mx{background:var(--card);border:1px solid var(--line);border-radius:16px;padding:16px 16px 6px;margin-bottom:32px;}
  .mxrow{display:flex;gap:10px;padding:9px 0;border-bottom:1px solid var(--line);align-items:flex-start;}
  .mxrow:last-child{border-bottom:none;}
  .mxk{font-weight:700;font-size:11.5px;width:96px;flex:none;color:var(--ink);line-height:1.4;}
  .mxk small{display:block;font-weight:500;color:var(--muted);font-size:10px;}
  .mxv{font-size:11.5px;color:var(--ink-soft);}

  /* brand block */
  .b{background:var(--card);border:1px solid var(--line);border-radius:18px;padding:18px 17px 17px;margin-bottom:15px;position:relative;}
  .b-h{display:flex;gap:11px;align-items:baseline;margin-bottom:3px;}
  .b-no{font-family:"Fraunces",serif;font-size:15px;font-weight:600;color:var(--accent);flex:none;}
  .b-nm{font-weight:700;font-size:16.5px;letter-spacing:.02em;}
  .b-tag{font-size:11px;color:var(--accent);margin:0 0 2px 26px;}
  .b-biz{font-size:11.5px;color:var(--muted);margin:0 0 12px 26px;}
  .chan{display:inline-flex;align-items:center;gap:6px;font-weight:700;font-size:10.5px;border-radius:999px;padding:3px 11px;margin:0 0 11px 26px;}
  .chan.ig{color:#A6371F;background:#F4E2D8;}
  .chan.sales{color:#4A5340;background:#E2E7D8;}
  .chan.local{color:#6B5A36;background:#EEE6CF;}
  .b-row{padding-left:26px;}
  .b-lab{font-family:"Fraunces",serif;font-size:9px;letter-spacing:.26em;text-transform:uppercase;color:var(--muted);margin:10px 0 5px;}
  .b-target{font-size:12px;color:var(--ink-soft);}
  ul.todo{list-style:none;}
  ul.todo li{font-size:12.5px;padding:4px 0 4px 16px;position:relative;line-height:1.5;}
  ul.todo li::before{content:"";position:absolute;left:0;top:9px;width:5px;height:5px;border-radius:50%;background:var(--accent);}
  ul.todo li b{font-weight:700;}
  .angle{font-size:12px;color:var(--ink-soft);background:var(--paper);border-left:2px solid var(--accent);border-radius:0 8px 8px 0;padding:9px 12px;margin-top:4px;}
  .angle b{color:var(--ink);font-weight:700;}
  .ref{font-size:10.5px;color:var(--muted);margin:8px 0 0 26px;font-style:italic;}

  /* order */
  .order{margin-bottom:10px;}
  .o{display:flex;gap:12px;padding:12px 0;border-bottom:1px solid var(--line);}
  .o:first-of-type{border-top:1px solid var(--line);}
  .o .on{font-family:"Fraunces",serif;font-size:14px;font-weight:600;color:var(--accent);width:18px;flex:none;line-height:1.4;}
  .o .od{font-size:12.5px;}
  .o .od b{font-weight:700;}

  .next{margin-top:26px;text-align:center;}
  .next .arw{color:var(--accent);font-size:16px;line-height:1;}
  .next .box{margin-top:9px;display:inline-block;background:var(--ink);color:var(--paper2);border-radius:14px;padding:14px 22px;text-align:left;max-width:100%;}
  .next .box span{display:block;font-family:"Fraunces",serif;font-size:9px;letter-spacing:.24em;text-transform:uppercase;color:var(--accent-soft);margin-bottom:4px;}
  .next .box b{font-weight:700;font-size:13.5px;letter-spacing:.01em;line-height:1.5;}
  .foot{text-align:center;margin-top:30px;font-family:"Fraunces",serif;font-size:10px;letter-spacing:.28em;text-transform:uppercase;color:var(--muted);}

  /* 全社 数値サマリー */
  .sumgrid{display:grid;grid-template-columns:1fr 1fr;gap:9px;margin-bottom:13px;}
  .sum{background:var(--card);border:1px solid var(--line);border-radius:16px;padding:14px 14px 12px;position:relative;overflow:hidden;}
  .sum::after{content:"";position:absolute;left:14px;bottom:0;width:20px;height:3px;background:var(--accent);border-radius:3px;}
  .sum-n{font-family:"Fraunces",serif;font-weight:600;font-size:25px;line-height:1;letter-spacing:-.01em;}
  .sum-n small{font-family:"Zen Kaku Gothic New",sans-serif;font-size:11px;font-weight:700;margin-left:2px;}
  .sum-c{font-size:10px;color:var(--muted);margin-top:8px;letter-spacing:.01em;}
  .pbar{background:var(--card);border:1px solid var(--line);border-radius:16px;padding:14px 15px;margin-bottom:11px;}
  .pbar-h{font-weight:700;font-size:12px;margin-bottom:10px;}
  .pl{display:flex;align-items:center;gap:9px;margin:7px 0;}
  .pl-k{font-size:10px;color:var(--muted);width:50px;flex:none;}
  .pl-t{flex:1;height:8px;background:var(--paper);border-radius:99px;overflow:hidden;}
  .pl-t i{display:block;height:100%;background:var(--line);border-radius:99px;}
  .pl-v{font-family:"Fraunces",serif;font-size:12.5px;width:46px;text-align:right;flex:none;}
  .note{font-size:10.5px;color:var(--muted);line-height:1.6;margin:2px 0 32px;}
  .note b{color:var(--ink-soft);font-weight:700;}

  /* ブランド別 KPI */
  .kpi{display:grid;grid-template-columns:1fr 1fr 1fr;gap:7px;margin:1px 0 3px;}
  .kpi-i{background:var(--paper);border:1px solid var(--line);border-radius:11px;padding:9px 7px 8px;text-align:center;}
  .kpi-n{font-family:"Fraunces",serif;font-weight:600;font-size:15.5px;line-height:1.05;color:var(--ink);}
  .kpi-n small{font-family:"Zen Kaku Gothic New",sans-serif;font-size:9px;font-weight:700;color:var(--accent);margin-left:2px;}
  .kpi-c{font-size:8.5px;color:var(--muted);margin-top:5px;letter-spacing:.01em;}

  /* 中間マイルストーン */
  .ms{background:var(--card);border:1px solid var(--line);border-radius:16px;padding:4px 14px;margin-bottom:11px;}
  .ms-r{display:grid;grid-template-columns:54px 1fr 1fr 1fr 1fr;gap:4px;align-items:center;padding:9px 0;border-bottom:1px solid var(--line);}
  .ms-r:last-child{border-bottom:none;}
  .ms-r span{font-size:11px;text-align:right;font-variant-numeric:tabular-nums;color:var(--ink-soft);}
  .ms-r span:first-child{text-align:left;}
  .ms-head span{font-size:8.5px;color:var(--muted);letter-spacing:.02em;font-weight:700;}
  .ms-y{font-weight:700;font-size:10.5px !important;color:var(--ink) !important;}
  .ms-now span{color:var(--muted);}
  .ms-goal{background:#FBEFE9;border-radius:10px;margin:2px -6px;padding-left:6px;padding-right:6px;}
  .ms-goal span{color:var(--accent) !important;font-weight:700;}

  /* 給与の根拠 */
  .pay{margin-bottom:8px;}
  .pay .f .fn{color:var(--accent);}
  .keybox{font-size:12px;color:var(--ink-soft);background:var(--paper);border-left:2px solid var(--accent);border-radius:0 8px 8px 0;padding:11px 13px;margin:12px 0 30px;line-height:1.6;}
  .keybox b{color:var(--ink);font-weight:700;}
</style>
<meta name="apple-mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-status-bar-style" content="default" />
<meta name="theme-color" content="#f7f3ea" />
<link rel="manifest" href="manifest.json" />
<link rel="apple-touch-icon" href="icons/icon-192.png" />
</head>
<body>
<div class="wrap">

  <div class="bar reveal" style="animation-delay:.02s">
    <div class="brand">
      <div class="mark"></div>
      <div><b>Rose Garden Co., Ltd</b><span>Brand Playbook</span></div>
    </div>
    <div class="date">7 BRANDS</div>
  </div>

  <!-- INTRO -->
  <div class="reveal" style="animation-delay:.08s">
    <div class="eyebrow">Brand Playbook</div>
    <h1 class="lead">ブランドは7つでも、<em>エンジンは1つ</em>。</h1>
    <p class="lead-sub">どのブランドも「植物 × 心理学」「0.5秒で心を掴む」「ロジックで語る」という共通の型の上で動かします。ここではブランド別に〈主戦場 → ToDo → 集客／広告の切り口〉を1枚で整理しました。</p>
  </div>

  <!-- 全社 数値目標 -->
  <div class="reveal" style="animation-delay:.11s">
    <div class="eyebrow">Numbers ｜ 5年後の数値目標（全社）</div>
    <div class="sumgrid">
      <div class="sum"><div class="sum-n">3<small>億円</small></div><div class="sum-c">売上目標（7ブランド合計）</div></div>
      <div class="sum"><div class="sum-n">4,070<small>万円</small></div><div class="sum-c">営業利益目標</div></div>
      <div class="sum"><div class="sum-n">約13<small>%</small></div><div class="sum-c">営業利益率（目標）</div></div>
      <div class="sum"><div class="sum-n">+65<small>万円</small></div><div class="sum-c">平均年収UP／人（+月約5万円）</div></div>
    </div>
    <div class="pbar">
      <div class="pbar-h">営業利益率の改善目標</div>
      <div class="pl"><span class="pl-k">2025年度</span><div class="pl-t"><i style="width:3%"></i></div><span class="pl-v">0.5%</span></div>
      <div class="pl"><span class="pl-k">5年後</span><div class="pl-t"><i style="width:87%;background:var(--accent)"></i></div><span class="pl-v">約13%</span></div>
    </div>
    <p class="note">＊数字は MVV（売上3億円／正社員12名／2025年度利益率0.5%）から逆算した<b>たたき台（仮置き）</b>です。各事業部の実績値に置き換えてご調整ください。昇給・賞与原資は各事業部の営業利益の20%として算出。</p>
  </div>

  <!-- 中間マイルストーン -->
  <div class="reveal" style="animation-delay:.125s">
    <div class="eyebrow">Roadmap ｜ 中間マイルストーン（5年計画）</div>
    <div class="ms">
      <div class="ms-r ms-head"><span>年度</span><span>売上</span><span>利益率</span><span>営業利益</span><span>昇給原資</span></div>
      <div class="ms-r ms-now"><span class="ms-y">2025実績</span><span>0.8億</span><span>0.5%</span><span>40万</span><span>—</span></div>
      <div class="ms-r"><span class="ms-y">1年後</span><span>約1.0億</span><span>3%</span><span>310万</span><span>62万</span></div>
      <div class="ms-r"><span class="ms-y">2年後</span><span>約1.5億</span><span>6%</span><span>880万</span><span>176万</span></div>
      <div class="ms-r"><span class="ms-y">3年後</span><span>約2.0億</span><span>9%</span><span>1,850万</span><span>370万</span></div>
      <div class="ms-r"><span class="ms-y">4年後</span><span>2.6億</span><span>11%</span><span>2,860万</span><span>570万</span></div>
      <div class="ms-r ms-goal"><span class="ms-y">5年後</span><span>3.0億</span><span>約13%</span><span>4,070万</span><span>814万</span></div>
    </div>
    <p class="note">現状は<b>稼働3ブランドで8,000万</b>（IROHA 2,000・Misel 2,000・OEM 4,000）。<b>IROHAの単価UP＋残り4ブランドの立ち上げ</b>で3億へ。利益率は前半で大きく改善（仕組み化・属人性の排除が効く時期）→ 後半は微増で着地。利益が増えた分だけ昇給原資が開く。<b>＊人数（→12名）は仮置き</b>。</p>
  </div>

  <!-- 給与UPの根拠 -->
  <div class="pay reveal" style="animation-delay:.135s">
    <div class="eyebrow">Pay Logic ｜ みんなの給与が増える仕組み</div>
    <div class="f"><span class="fn">01</span><span class="ft"><b>会社の利益の20%は、必ずチームに還元</b>　各事業部の営業利益の20%を昇給・賞与の原資にします。会社が成長した分は、みんなの収入に回ります。</span></div>
    <div class="f"><span class="fn">02</span><span class="ft"><b>成果が出た年は、しっかり賞与で</b>　利益が伸びた分は決算賞与として還元。チームの頑張りが、数字でそのまま返ってきます。</span></div>
    <div class="f"><span class="fn">03</span><span class="ft"><b>ルールが先に決まっているから公平</b>　「誰かのさじ加減」ではなく〈利益×20%〉という決まったルール。だから見通しが立ち、納得して働けます。</span></div>
    <div class="f"><span class="fn">04</span><span class="ft"><b>目標を達成するほど、原資が増える</b>　各事業部が目標に近づくほど還元の原資も大きくなる。チームで仕組みを回すほど、一人ひとりの取り分も増えます。</span></div>
    <div class="keybox"><b>会社が成長すれば、給与も上がる。</b>5年後の目標は、営業利益4,070万円 → その20%＝<b>814万円</b>をチームへ還元。1人あたり平均で<b>年+65万円（月+約5万円）</b>を目指します。</div>
  </div>

  <!-- 共通の土台 -->
  <div class="found reveal" style="animation-delay:.14s">
    <div class="eyebrow">Foundation ｜ 全ブランド共通</div>
    <div class="f"><span class="fn">01</span><span class="ft"><b>「0.5秒」の型を共通化</b>　1枚目・ファーストカットの設計ルールを全ブランドで統一</span></div>
    <div class="f"><span class="fn">02</span><span class="ft"><b>実績を撮り溜める仕組み</b>　ビフォーアフター／作品／導入事例を案件ごとに必ず記録</span></div>
    <div class="f"><span class="fn">03</span><span class="ft"><b>問い合わせ導線を統一</b>　IG→LINE／サイト／相談 の受け皿フォーマットを横展開</span></div>
    <div class="f"><span class="fn">04</span><span class="ft"><b>週次で数値を見る</b>　保存・プロフィール遷移・問い合わせ・受注を全ブランド同じ指標で</span></div>
  </div>

  <!-- チャネル適性 -->
  <div class="reveal" style="animation-delay:.2s">
    <div class="eyebrow">Channel Fit ｜ 主戦場の見極め</div>
    <div class="mx">
      <div class="mxrow"><div class="mxk">Instagram＋自社HP主導<small>視覚で魅せ／SEOで獲る</small></div><div class="mxv">IROHAD'ECOR・TSUBOMI・Misel・mi.___&amp;・arinomama</div></div>
      <div class="mxrow"><div class="mxk">営業・法人主導<small>IGは認知補助</small></div><div class="mxv">OEM・結（Yui）</div></div>
      <div class="mxrow"><div class="mxk">ローカル/MEO<small>地域密着で併用</small></div><div class="mxv">Misel・mi.___&amp;</div></div>
    </div>
  </div>

  <div class="eyebrow reveal" style="animation-delay:.24s">Brands</div>

  <!-- 1 IROHAD'ECOR -->
  <div class="b reveal" style="animation-delay:.26s">
    <div class="b-h"><span class="b-no">1</span><span class="b-nm">IROHAD'ECOR</span></div>
    <div class="b-tag">〜一目惚れ設計学〜</div>
    <div class="b-biz">空間装飾・空間コンサル事業</div>
    <span class="chan ig">Instagram主導 ＋ 法人紹介</span>
    <div class="b-row">
      <div class="b-lab">数値目標（5年後）</div>
      <div class="kpi">
        <div class="kpi-i"><div class="kpi-n">1億円</div><div class="kpi-c">目標（現状2,000万）</div></div>
        <div class="kpi-i"><div class="kpi-n">1,500万<small>率15%</small></div><div class="kpi-c">営業利益</div></div>
        <div class="kpi-i"><div class="kpi-n">+300万</div><div class="kpi-c">昇給・賞与原資</div></div>
      </div>
      <div class="b-lab">Target</div>
      <div class="b-target">「印象で集客したい」店舗・商業施設・オフィスの事業者／<b>イベント・PR・広告会社</b>（博報堂 等）</div>
      <div class="b-lab">To-Do</div>
      <ul class="todo">
        <li><b>りなが顔出し</b>で YouTube・リールを発信（宣伝の主役に）</li>
        <li><b>ビフォーアフター動画は必須化</b>（全案件で記録）</li>
        <li><b>モデルルームへの来客導線</b>をつくる</li>
        <li><b>無料相談・公式LINE</b>の問い合わせを増やす</li>
      </ul>
      <div class="b-lab">Ad / 集客</div>
      <div class="angle"><b>ビフォーアフター動画で“変化”を見せる。</b>「装飾で売上が上がる理由」を心理学ロジックで語るカルーセル → 無料相談・資料請求のリード獲得。</div>
      <div class="b-lab">OEMとの棲み分け</div>
      <div class="angle"><b>博報堂・PR会社の案件はIROHAD'ECORが担当。</b>企画から空間に落とし込む上流の仕事は、設計・制作まで一貫してIROHAD'ECORで受ける。OEM事業部とは<b>取引先を分けて</b>棲み分ける。</div>
    </div>
  </div>

  <!-- 2 OEM -->
  <div class="b reveal" style="animation-delay:.3s">
    <div class="b-h"><span class="b-no">2</span><span class="b-nm">OEM</span></div>
    <div class="b-tag">〜センスの良い相方〜</div>
    <div class="b-biz">装飾品の制作代行</div>
    <span class="chan sales">B2B営業主導（IGは実績ショーケース）</span>
    <div class="b-row">
      <div class="b-lab">数値目標（5年後）</div>
      <div class="kpi">
